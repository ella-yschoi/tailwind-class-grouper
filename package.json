{
  "name": "tailwind-class-grouper",
  "displayName": "Tailwind Class Grouper",
  "description": "Group Tailwind CSS classes into readable blocks using clsx.",
  "version": "0.1.0",
  "publisher": "ella-yschoi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ella-yschoi/tailwind-class-grouper"
  },
  "homepage": "https://github.com/ella-yschoi/tailwind-class-grouper#readme",
  "bugs": {
    "url": "https://github.com/ella-yschoi/tailwind-class-grouper/issues"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "clsx",
    "class-grouper",
    "formatter"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Formatters"
  ],
  "icon": "images/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tailwind-class-grouper.groupClasses",
        "title": "Tailwind: Group Classes"
      }
    ],
    "keybindings": [
      {
        "command": "tailwind-class-grouper.groupClasses",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node dist/test/extension.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "undici": "^5.28.0"
  }
}
